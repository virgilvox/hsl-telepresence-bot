# Copy to /etc/hsl-telepresence/robot.env and edit. Read by the systemd unit.

# Identity and relay
ROBOT_ID=hsl-bot-1
ROBOT_NAME=hsl-telepresence-robot
CLASP_URL=wss://relay.clasp.to
# Leave unset for anonymous. Set to a cpsk_... token if the relay requires auth.
# CLASP_TOKEN=

# Motor HAT (Adafruit DC+Stepper, PCA9685)
I2C_BUS=/dev/i2c-1
I2C_ADDRESS=0x60
DRIVE_TIMEOUT_MS=400
MAX_SPEED=1.0

# Stereoscopic USB camera. Confirm the device and its side-by-side modes with:
#   v4l2-ctl -d /dev/video0 --list-formats-ext
# Keep the width at or below 1920: the Pi's hardware H264 encoder will not go
# wider. 1280x480 (two 640x480 halves) is a good fit for the Pi 3B+.
#
# Prefer a stable /dev/v4l/by-id/*-video-index0 path over a bare /dev/videoN:
# the USB camera can re-enumerate onto a different number after a power glitch,
# and the by-id symlink always points at its capture node. List them with:
#   ls /dev/v4l/by-id/
# If the configured node is missing at stream time the agent falls back to the
# first by-id capture node on its own, but naming it here avoids the first miss.
CAMERA_DEVICE=/dev/v4l/by-id/usb-3D_USB_Camera_3D_USB_Camera-video-index0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Logging
RUST_LOG=info,hsl_telepresence_robot=debug
